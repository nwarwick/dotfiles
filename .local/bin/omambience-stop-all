#!/bin/bash
# Stop every running omambience sound. Per-sound volumes are preserved.

set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/omambience"
[[ -d "$STATE_DIR" ]] || exit 0

shopt -s nullglob
for sock in "$STATE_DIR"/*.sock; do
  pkill -f -- "--input-ipc-server=$sock" 2>/dev/null || true
  rm -f "$sock"
done
